# ============================================================
# Ye Project — Environment Variables Template
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ---- Environment ----
# development: warnings only; production: hard refusal to start with insecure config
ENV=development

# ---- App ----
APP_NAME="AI Coding Assistant"
VERSION=0.1.0
DEBUG=true

# ---- Server ----
HOST=0.0.0.0
PORT=8765

# ---- Security (CRITICAL) ----
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=REPLACE_ME_WITH_A_RANDOM_64_CHAR_STRING

# ---- CORS (whitelist) ----
# Comma-separated list of allowed origins. NO wildcards in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ---- Zhipu AI ----
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4/
ZHIPU_MODEL=glm-5.1

# ---- Database ----
DATABASE_URL=sqlite+aiosqlite:///./data/assistant.db

# ---- Storage ----
DATA_DIR=./data
PROJECTS_DIR=./data/projects

# ---- Terminal sandbox ----
COMMAND_TIMEOUT=60
MAX_OUTPUT_SIZE=1048576
